{
  "_comment": "cave-home-water Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Water meters + leak sensors.",
  "_planned_panels": [
    {
      "title": "water — event/tick rate",
      "expr": "rate(cave_home_water_tick_total[1m])"
    },
    {
      "title": "water — error rate (5m)",
      "expr": "rate(cave_home_water_error_total[5m])"
    },
    {
      "title": "water — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_water_request_seconds_bucket[5m]))"
    },
    {
      "title": "water — active entities / sessions",
      "expr": "cave_home_water_active_total"
    },
    {
      "title": "water — bytes in/out",
      "expr": "rate(cave_home_water_bytes_in_total[1m]) + rate(cave_home_water_bytes_out_total[1m])"
    },
    {
      "title": "water — last-success age (s)",
      "expr": "time() - cave_home_water_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "A water sensor went offline"
}
