{
  "_comment": "cave-home-household Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Chores, shopping list, presence.",
  "_planned_panels": [
    {
      "title": "household — event/tick rate",
      "expr": "rate(cave_home_household_tick_total[1m])"
    },
    {
      "title": "household — error rate (5m)",
      "expr": "rate(cave_home_household_error_total[5m])"
    },
    {
      "title": "household — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_household_request_seconds_bucket[5m]))"
    },
    {
      "title": "household — active entities / sessions",
      "expr": "cave_home_household_active_total"
    },
    {
      "title": "household — bytes in/out",
      "expr": "rate(cave_home_household_bytes_in_total[1m]) + rate(cave_home_household_bytes_out_total[1m])"
    },
    {
      "title": "household — last-success age (s)",
      "expr": "time() - cave_home_household_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Household helpers stopped working"
}
