{
  "_comment": "cave-home-garden Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Irrigation + soil sensors.",
  "_planned_panels": [
    {
      "title": "garden — event/tick rate",
      "expr": "rate(cave_home_garden_tick_total[1m])"
    },
    {
      "title": "garden — error rate (5m)",
      "expr": "rate(cave_home_garden_error_total[5m])"
    },
    {
      "title": "garden — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_garden_request_seconds_bucket[5m]))"
    },
    {
      "title": "garden — active entities / sessions",
      "expr": "cave_home_garden_active_total"
    },
    {
      "title": "garden — bytes in/out",
      "expr": "rate(cave_home_garden_bytes_in_total[1m]) + rate(cave_home_garden_bytes_out_total[1m])"
    },
    {
      "title": "garden — last-success age (s)",
      "expr": "time() - cave_home_garden_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "An irrigation valve went offline"
}
