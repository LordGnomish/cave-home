{
  "_comment": "cave-home-zwave Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Z-Wave JS bridge.",
  "_planned_panels": [
    {
      "title": "zwave — event/tick rate",
      "expr": "rate(cave_home_zwave_tick_total[1m])"
    },
    {
      "title": "zwave — error rate (5m)",
      "expr": "rate(cave_home_zwave_error_total[5m])"
    },
    {
      "title": "zwave — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_zwave_request_seconds_bucket[5m]))"
    },
    {
      "title": "zwave — active entities / sessions",
      "expr": "cave_home_zwave_active_total"
    },
    {
      "title": "zwave — bytes in/out",
      "expr": "rate(cave_home_zwave_bytes_in_total[1m]) + rate(cave_home_zwave_bytes_out_total[1m])"
    },
    {
      "title": "zwave — last-success age (s)",
      "expr": "time() - cave_home_zwave_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Z-Wave devices stopped responding"
}
