{
  "_comment": "cave-home-wellness Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Sleep / activity / mood.",
  "_planned_panels": [
    {
      "title": "wellness — event/tick rate",
      "expr": "rate(cave_home_wellness_tick_total[1m])"
    },
    {
      "title": "wellness — error rate (5m)",
      "expr": "rate(cave_home_wellness_error_total[5m])"
    },
    {
      "title": "wellness — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_wellness_request_seconds_bucket[5m]))"
    },
    {
      "title": "wellness — active entities / sessions",
      "expr": "cave_home_wellness_active_total"
    },
    {
      "title": "wellness — bytes in/out",
      "expr": "rate(cave_home_wellness_bytes_in_total[1m]) + rate(cave_home_wellness_bytes_out_total[1m])"
    },
    {
      "title": "wellness — last-success age (s)",
      "expr": "time() - cave_home_wellness_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "A wellness sensor went offline"
}
