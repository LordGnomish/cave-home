{
  "_comment": "cave-home-alarm Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Intruder alarm panel.",
  "_planned_panels": [
    {
      "title": "alarm — event/tick rate",
      "expr": "rate(cave_home_alarm_tick_total[1m])"
    },
    {
      "title": "alarm — error rate (5m)",
      "expr": "rate(cave_home_alarm_error_total[5m])"
    },
    {
      "title": "alarm — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_alarm_request_seconds_bucket[5m]))"
    },
    {
      "title": "alarm — active entities / sessions",
      "expr": "cave_home_alarm_active_total"
    },
    {
      "title": "alarm — bytes in/out",
      "expr": "rate(cave_home_alarm_bytes_in_total[1m]) + rate(cave_home_alarm_bytes_out_total[1m])"
    },
    {
      "title": "alarm — last-success age (s)",
      "expr": "time() - cave_home_alarm_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "The alarm panel went offline"
}
