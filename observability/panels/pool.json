{
  "_comment": "cave-home-pool Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Pool pump + heater control.",
  "_planned_panels": [
    {
      "title": "pool — event/tick rate",
      "expr": "rate(cave_home_pool_tick_total[1m])"
    },
    {
      "title": "pool — error rate (5m)",
      "expr": "rate(cave_home_pool_error_total[5m])"
    },
    {
      "title": "pool — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_pool_request_seconds_bucket[5m]))"
    },
    {
      "title": "pool — active entities / sessions",
      "expr": "cave_home_pool_active_total"
    },
    {
      "title": "pool — bytes in/out",
      "expr": "rate(cave_home_pool_bytes_in_total[1m]) + rate(cave_home_pool_bytes_out_total[1m])"
    },
    {
      "title": "pool — last-success age (s)",
      "expr": "time() - cave_home_pool_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "The pool controller went offline"
}
