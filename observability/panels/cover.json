{
  "_comment": "cave-home-cover Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Blinds + garage doors.",
  "_planned_panels": [
    {
      "title": "cover — event/tick rate",
      "expr": "rate(cave_home_cover_tick_total[1m])"
    },
    {
      "title": "cover — error rate (5m)",
      "expr": "rate(cave_home_cover_error_total[5m])"
    },
    {
      "title": "cover — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_cover_request_seconds_bucket[5m]))"
    },
    {
      "title": "cover — active entities / sessions",
      "expr": "cave_home_cover_active_total"
    },
    {
      "title": "cover — bytes in/out",
      "expr": "rate(cave_home_cover_bytes_in_total[1m]) + rate(cave_home_cover_bytes_out_total[1m])"
    },
    {
      "title": "cover — last-success age (s)",
      "expr": "time() - cave_home_cover_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "A blind or garage door stopped responding"
}
