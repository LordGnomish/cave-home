{
  "_comment": "cave-home-audio-mopidy Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Mopidy music daemon.",
  "_planned_panels": [
    {
      "title": "audio-mopidy — event/tick rate",
      "expr": "rate(cave_home_audio_mopidy_tick_total[1m])"
    },
    {
      "title": "audio-mopidy — error rate (5m)",
      "expr": "rate(cave_home_audio_mopidy_error_total[5m])"
    },
    {
      "title": "audio-mopidy — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_audio_mopidy_request_seconds_bucket[5m]))"
    },
    {
      "title": "audio-mopidy — active entities / sessions",
      "expr": "cave_home_audio_mopidy_active_total"
    },
    {
      "title": "audio-mopidy — bytes in/out",
      "expr": "rate(cave_home_audio_mopidy_bytes_in_total[1m]) + rate(cave_home_audio_mopidy_bytes_out_total[1m])"
    },
    {
      "title": "audio-mopidy — last-success age (s)",
      "expr": "time() - cave_home_audio_mopidy_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Music daemon stopped"
}
