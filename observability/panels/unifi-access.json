{
  "_comment": "cave-home-unifi-access Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: UniFi Access door control.",
  "_planned_panels": [
    {
      "title": "unifi-access — event/tick rate",
      "expr": "rate(cave_home_unifi_access_tick_total[1m])"
    },
    {
      "title": "unifi-access — error rate (5m)",
      "expr": "rate(cave_home_unifi_access_error_total[5m])"
    },
    {
      "title": "unifi-access — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_unifi_access_request_seconds_bucket[5m]))"
    },
    {
      "title": "unifi-access — active entities / sessions",
      "expr": "cave_home_unifi_access_active_total"
    },
    {
      "title": "unifi-access — bytes in/out",
      "expr": "rate(cave_home_unifi_access_bytes_in_total[1m]) + rate(cave_home_unifi_access_bytes_out_total[1m])"
    },
    {
      "title": "unifi-access — last-success age (s)",
      "expr": "time() - cave_home_unifi_access_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "A door reader went offline"
}
