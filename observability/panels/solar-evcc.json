{
  "_comment": "cave-home-solar-evcc Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: evcc EV-charging surplus loop.",
  "_planned_panels": [
    {
      "title": "solar-evcc — event/tick rate",
      "expr": "rate(cave_home_solar_evcc_tick_total[1m])"
    },
    {
      "title": "solar-evcc — error rate (5m)",
      "expr": "rate(cave_home_solar_evcc_error_total[5m])"
    },
    {
      "title": "solar-evcc — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_solar_evcc_request_seconds_bucket[5m]))"
    },
    {
      "title": "solar-evcc — active entities / sessions",
      "expr": "cave_home_solar_evcc_active_total"
    },
    {
      "title": "solar-evcc — bytes in/out",
      "expr": "rate(cave_home_solar_evcc_bytes_in_total[1m]) + rate(cave_home_solar_evcc_bytes_out_total[1m])"
    },
    {
      "title": "solar-evcc — last-success age (s)",
      "expr": "time() - cave_home_solar_evcc_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "EV charging surplus loop stopped"
