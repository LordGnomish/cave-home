{
  "_comment": "cave-home-doorbell Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Doorbell button + chime.",
  "_planned_panels": [
    {
      "title": "doorbell — event/tick rate",
      "expr": "rate(cave_home_doorbell_tick_total[1m])"
    },
    {
      "title": "doorbell — error rate (5m)",
      "expr": "rate(cave_home_doorbell_error_total[5m])"
    },
    {
      "title": "doorbell — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_doorbell_request_seconds_bucket[5m]))"
    },
    {
      "title": "doorbell — active entities / sessions",
      "expr": "cave_home_doorbell_active_total"
    },
    {
      "title": "doorbell — bytes in/out",
      "expr": "rate(cave_home_doorbell_bytes_in_total[1m]) + rate(cave_home_doorbell_bytes_out_total[1m])"
    },
    {
      "title": "doorbell — last-success age (s)",
      "expr": "time() - cave_home_doorbell_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "The doorbell went offline"
}
