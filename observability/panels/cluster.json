{
  "_comment": "cave-home-cluster Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: cluster bootstrap + join.",
  "_planned_panels": [
    {
      "title": "cluster — event/tick rate",
      "expr": "rate(cave_home_cluster_tick_total[1m])"
    },
    {
      "title": "cluster — error rate (5m)",
      "expr": "rate(cave_home_cluster_error_total[5m])"
    },
    {
      "title": "cluster — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_cluster_request_seconds_bucket[5m]))"
    },
    {
      "title": "cluster — active entities / sessions",
      "expr": "cave_home_cluster_active_total"
    },
    {
      "title": "cluster — bytes in/out",
      "expr": "rate(cave_home_cluster_bytes_in_total[1m]) + rate(cave_home_cluster_bytes_out_total[1m])"
    },
    {
      "title": "cluster — last-success age (s)",
      "expr": "time() - cave_home_cluster_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": null
}
