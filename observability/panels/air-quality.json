{
  "_comment": "cave-home-air-quality Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Indoor air quality sensors.",
  "_planned_panels": [
    {
      "title": "air-quality — event/tick rate",
      "expr": "rate(cave_home_air_quality_tick_total[1m])"
    },
    {
      "title": "air-quality — error rate (5m)",
      "expr": "rate(cave_home_air_quality_error_total[5m])"
    },
    {
      "title": "air-quality — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_air_quality_request_seconds_bucket[5m]))"
    },
    {
      "title": "air-quality — active entities / sessions",
      "expr": "cave_home_air_quality_active_total"
    },
    {
      "title": "air-quality — bytes in/out",
      "expr": "rate(cave_home_air_quality_bytes_in_total[1m]) + rate(cave_home_air_quality_bytes_out_total[1m])"
    },
    {
      "title": "air-quality — last-success age (s)",
      "expr": "time() - cave_home_air_quality_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "An air quality sensor went offline"
}
