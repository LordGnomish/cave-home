{
  "_comment": "cave-home-solar-sunspec Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: SunSpec Modbus inverter probe.",
  "_planned_panels": [
    {
      "title": "solar-sunspec — event/tick rate",
      "expr": "rate(cave_home_solar_sunspec_tick_total[1m])"
    },
    {
      "title": "solar-sunspec — error rate (5m)",
      "expr": "rate(cave_home_solar_sunspec_error_total[5m])"
    },
    {
      "title": "solar-sunspec — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_solar_sunspec_request_seconds_bucket[5m]))"
    },
    {
      "title": "solar-sunspec — active entities / sessions",
      "expr": "cave_home_solar_sunspec_active_total"
    },
    {
      "title": "solar-sunspec — bytes in/out",
      "expr": "rate(cave_home_solar_sunspec_bytes_in_total[1m]) + rate(cave_home_solar_sunspec_bytes_out_total[1m])"
    },
    {
      "title": "solar-sunspec — last-success age (s)",
      "expr": "time() - cave_home_solar_sunspec_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Solar inverter stopped responding"
}
