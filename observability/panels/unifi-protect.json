{
  "_comment": "cave-home-unifi-protect Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: UniFi Protect NVR bridge.",
  "_planned_panels": [
    {
      "title": "unifi-protect — event/tick rate",
      "expr": "rate(cave_home_unifi_protect_tick_total[1m])"
    },
    {
      "title": "unifi-protect — error rate (5m)",
      "expr": "rate(cave_home_unifi_protect_error_total[5m])"
    },
    {
      "title": "unifi-protect — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_unifi_protect_request_seconds_bucket[5m]))"
    },
    {
      "title": "unifi-protect — active entities / sessions",
      "expr": "cave_home_unifi_protect_active_total"
    },
    {
      "title": "unifi-protect — bytes in/out",
      "expr": "rate(cave_home_unifi_protect_bytes_in_total[1m]) + rate(cave_home_unifi_protect_bytes_out_total[1m])"
    },
    {
      "title": "unifi-protect — last-success age (s)",
      "expr": "time() - cave_home_unifi_protect_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Security cameras went offline"
}
