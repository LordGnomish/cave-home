{
  "_comment": "cave-home-unifi-talk Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: UniFi Talk softphone.",
  "_planned_panels": [
    {
      "title": "unifi-talk — event/tick rate",
      "expr": "rate(cave_home_unifi_talk_tick_total[1m])"
    },
    {
      "title": "unifi-talk — error rate (5m)",
      "expr": "rate(cave_home_unifi_talk_error_total[5m])"
    },
    {
      "title": "unifi-talk — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_unifi_talk_request_seconds_bucket[5m]))"
    },
    {
      "title": "unifi-talk — active entities / sessions",
      "expr": "cave_home_unifi_talk_active_total"
    },
    {
      "title": "unifi-talk — bytes in/out",
      "expr": "rate(cave_home_unifi_talk_bytes_in_total[1m]) + rate(cave_home_unifi_talk_bytes_out_total[1m])"
    },
    {
      "title": "unifi-talk — last-success age (s)",
      "expr": "time() - cave_home_unifi_talk_last_success_timestamp_seconds"
    }
  ],
