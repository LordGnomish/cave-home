{
  "_comment": "cave-home-history Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Long-term state history.",
  "_planned_panels": [
    {
      "title": "history — event/tick rate",
      "expr": "rate(cave_home_history_tick_total[1m])"
    },
    {
      "title": "history — error rate (5m)",
      "expr": "rate(cave_home_history_error_total[5m])"
    },
    {
      "title": "history — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_history_request_seconds_bucket[5m]))"
    },
    {
      "title": "history — active entities / sessions",
      "expr": "cave_home_history_active_total"
    },
    {
      "title": "history — bytes in/out",
      "expr": "rate(cave_home_history_bytes_in_total[1m]) + rate(cave_home_history_bytes_out_total[1m])"
    },
    {
      "title": "history — last-success age (s)",
      "expr": "time() - cave_home_history_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "History recording stopped"
}
