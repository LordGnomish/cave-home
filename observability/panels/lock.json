{
  "_comment": "cave-home-lock Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Smart locks.",
  "_planned_panels": [
    {
      "title": "lock — event/tick rate",
      "expr": "rate(cave_home_lock_tick_total[1m])"
    },
    {
      "title": "lock — error rate (5m)",
      "expr": "rate(cave_home_lock_error_total[5m])"
    },
    {
      "title": "lock — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_lock_request_seconds_bucket[5m]))"
    },
    {
      "title": "lock — active entities / sessions",
      "expr": "cave_home_lock_active_total"
    },
    {
      "title": "lock — bytes in/out",
      "expr": "rate(cave_home_lock_bytes_in_total[1m]) + rate(cave_home_lock_bytes_out_total[1m])"
    },
    {
      "title": "lock — last-success age (s)",
      "expr": "time() - cave_home_lock_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "A smart lock stopped responding"
}
