{
  "_comment": "cave-home-unifi-network Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: UniFi Network controller bridge.",
  "_planned_panels": [
    {
      "title": "unifi-network — event/tick rate",
      "expr": "rate(cave_home_unifi_network_tick_total[1m])"
    },
    {
      "title": "unifi-network — error rate (5m)",
      "expr": "rate(cave_home_unifi_network_error_total[5m])"
    },
    {
      "title": "unifi-network — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_unifi_network_request_seconds_bucket[5m]))"
    },
    {
      "title": "unifi-network — active entities / sessions",
      "expr": "cave_home_unifi_network_active_total"
    },
    {
      "title": "unifi-network — bytes in/out",
      "expr": "rate(cave_home_unifi_network_bytes_in_total[1m]) + rate(cave_home_unifi_network_bytes_out_total[1m])"
    },
    {
      "title": "unifi-network — last-success age (s)",
      "expr": "time() - cave_home_unifi_network_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Wi-Fi gateway went offline"
}
