{
  "_comment": "cave-home-dns-unbound Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Unbound recursive DNS.",
  "_planned_panels": [
    {
      "title": "dns-unbound — event/tick rate",
      "expr": "rate(cave_home_dns_unbound_tick_total[1m])"
    },
    {
      "title": "dns-unbound — error rate (5m)",
      "expr": "rate(cave_home_dns_unbound_error_total[5m])"
    },
    {
      "title": "dns-unbound — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_dns_unbound_request_seconds_bucket[5m]))"
    },
    {
      "title": "dns-unbound — active entities / sessions",
      "expr": "cave_home_dns_unbound_active_total"
    },
    {
      "title": "dns-unbound — bytes in/out",
      "expr": "rate(cave_home_dns_unbound_bytes_in_total[1m]) + rate(cave_home_dns_unbound_bytes_out_total[1m])"
    },
    {
      "title": "dns-unbound — last-success age (s)",
      "expr": "time() - cave_home_dns_unbound_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Internet name lookups slowed down"
}
