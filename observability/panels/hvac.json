{
  "_comment": "cave-home-hvac Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Thermostats + ducted HVAC.",
  "_planned_panels": [
    {
      "title": "hvac — event/tick rate",
      "expr": "rate(cave_home_hvac_tick_total[1m])"
    },
    {
      "title": "hvac — error rate (5m)",
      "expr": "rate(cave_home_hvac_error_total[5m])"
    },
    {
      "title": "hvac — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_hvac_request_seconds_bucket[5m]))"
    },
    {
      "title": "hvac — active entities / sessions",
      "expr": "cave_home_hvac_active_total"
    },
    {
      "title": "hvac — bytes in/out",
      "expr": "rate(cave_home_hvac_bytes_in_total[1m]) + rate(cave_home_hvac_bytes_out_total[1m])"
    },
    {
      "title": "hvac — last-success age (s)",
      "expr": "time() - cave_home_hvac_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "The thermostat went offline"
}
