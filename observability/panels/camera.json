{
  "_comment": "cave-home-camera Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: ONVIF/RTSP/WebRTC camera bridge.",
  "_planned_panels": [
    {
      "title": "camera — event/tick rate",
      "expr": "rate(cave_home_camera_tick_total[1m])"
    },
    {
      "title": "camera — error rate (5m)",
      "expr": "rate(cave_home_camera_error_total[5m])"
    },
    {
      "title": "camera — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_camera_request_seconds_bucket[5m]))"
    },
    {
      "title": "camera — active entities / sessions",
      "expr": "cave_home_camera_active_total"
    },
    {
      "title": "camera — bytes in/out",
      "expr": "rate(cave_home_camera_bytes_in_total[1m]) + rate(cave_home_camera_bytes_out_total[1m])"
    },
    {
      "title": "camera — last-success age (s)",
      "expr": "time() - cave_home_camera_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "A camera went offline"
}
