{
  "_comment": "cave-home-vacuum Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Robot vacuums.",
  "_planned_panels": [
    {
      "title": "vacuum — event/tick rate",
      "expr": "rate(cave_home_vacuum_tick_total[1m])"
    },
    {
      "title": "vacuum — error rate (5m)",
      "expr": "rate(cave_home_vacuum_error_total[5m])"
    },
    {
      "title": "vacuum — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_vacuum_request_seconds_bucket[5m]))"
    },
    {
      "title": "vacuum — active entities / sessions",
      "expr": "cave_home_vacuum_active_total"
    },
    {
      "title": "vacuum — bytes in/out",
      "expr": "rate(cave_home_vacuum_bytes_in_total[1m]) + rate(cave_home_vacuum_bytes_out_total[1m])"
    },
    {
      "title": "vacuum — last-success age (s)",
      "expr": "time() - cave_home_vacuum_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "The robot vacuum got stuck"
}
