{
  "_comment": "cave-home-cni-flannel Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: flannel CNI.",
  "_planned_panels": [
    {
      "title": "cni-flannel — event/tick rate",
      "expr": "rate(cave_home_cni_flannel_tick_total[1m])"
    },
    {
      "title": "cni-flannel — error rate (5m)",
      "expr": "rate(cave_home_cni_flannel_error_total[5m])"
    },
    {
      "title": "cni-flannel — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_cni_flannel_request_seconds_bucket[5m]))"
    },
    {
      "title": "cni-flannel — active entities / sessions",
      "expr": "cave_home_cni_flannel_active_total"
    },
    {
      "title": "cni-flannel — bytes in/out",
      "expr": "rate(cave_home_cni_flannel_bytes_in_total[1m]) + rate(cave_home_cni_flannel_bytes_out_total[1m])"
    },
    {
      "title": "cni-flannel — last-success age (s)",
      "expr": "time() - cave_home_cni_flannel_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": null
}
