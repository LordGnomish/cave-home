{
  "_comment": "cave-home-portal Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Lovelace-class web UI.",
  "_planned_panels": [
    {
      "title": "portal — event/tick rate",
      "expr": "rate(cave_home_portal_tick_total[1m])"
    },
    {
      "title": "portal — error rate (5m)",
      "expr": "rate(cave_home_portal_error_total[5m])"
    },
    {
      "title": "portal — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_portal_request_seconds_bucket[5m]))"
    },
    {
      "title": "portal — active entities / sessions",
      "expr": "cave_home_portal_active_total"
    },
    {
      "title": "portal — bytes in/out",
      "expr": "rate(cave_home_portal_bytes_in_total[1m]) + rate(cave_home_portal_bytes_out_total[1m])"
    },
    {
      "title": "portal — last-success age (s)",
      "expr": "time() - cave_home_portal_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": null
}
