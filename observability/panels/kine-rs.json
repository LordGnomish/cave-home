{
  "_comment": "cave-home-kine-rs Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: kine (sqlite-backed etcd shim).",
  "_planned_panels": [
    {
      "title": "kine-rs — event/tick rate",
      "expr": "rate(cave_home_kine_rs_tick_total[1m])"
    },
    {
      "title": "kine-rs — error rate (5m)",
      "expr": "rate(cave_home_kine_rs_error_total[5m])"
    },
    {
      "title": "kine-rs — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_kine_rs_request_seconds_bucket[5m]))"
    },
    {
      "title": "kine-rs — active entities / sessions",
      "expr": "cave_home_kine_rs_active_total"
    },
    {
      "title": "kine-rs — bytes in/out",
      "expr": "rate(cave_home_kine_rs_bytes_in_total[1m]) + rate(cave_home_kine_rs_bytes_out_total[1m])"
    },
    {
      "title": "kine-rs — last-success age (s)",
      "expr": "time() - cave_home_kine_rs_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": null
}
