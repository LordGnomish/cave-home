{
  "_comment": "cave-home-hue-bridge-emu Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Hue bridge emulator (legacy clients).",
  "_planned_panels": [
    {
      "title": "hue-bridge-emu — event/tick rate",
      "expr": "rate(cave_home_hue_bridge_emu_tick_total[1m])"
    },
    {
      "title": "hue-bridge-emu — error rate (5m)",
      "expr": "rate(cave_home_hue_bridge_emu_error_total[5m])"
    },
    {
      "title": "hue-bridge-emu — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_hue_bridge_emu_request_seconds_bucket[5m]))"
    },
    {
      "title": "hue-bridge-emu — active entities / sessions",
      "expr": "cave_home_hue_bridge_emu_active_total"
    },
    {
      "title": "hue-bridge-emu — bytes in/out",
      "expr": "rate(cave_home_hue_bridge_emu_bytes_in_total[1m]) + rate(cave_home_hue_bridge_emu_bytes_out_total[1m])"
    },
    {
      "title": "hue-bridge-emu — last-success age (s)",
      "expr": "time() - cave_home_hue_bridge_emu_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Legacy Hue clients lost the bridge"
}
