{
  "_comment": "cave-home-node-discovery Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: node discovery (mDNS).",
  "_planned_panels": [
    {
      "title": "node-discovery — event/tick rate",
      "expr": "rate(cave_home_node_discovery_tick_total[1m])"
    },
    {
      "title": "node-discovery — error rate (5m)",
      "expr": "rate(cave_home_node_discovery_error_total[5m])"
    },
    {
      "title": "node-discovery — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_node_discovery_request_seconds_bucket[5m]))"
    },
    {
      "title": "node-discovery — active entities / sessions",
      "expr": "cave_home_node_discovery_active_total"
    },
    {
      "title": "node-discovery — bytes in/out",
      "expr": "rate(cave_home_node_discovery_bytes_in_total[1m]) + rate(cave_home_node_discovery_bytes_out_total[1m])"
    },
    {
      "title": "node-discovery — last-success age (s)",
      "expr": "time() - cave_home_node_discovery_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": null
}
