{
  "_comment": "cave-home-dns-adguard Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: AdGuard Home DNS.",
  "_planned_panels": [
    {
      "title": "dns-adguard — event/tick rate",
      "expr": "rate(cave_home_dns_adguard_tick_total[1m])"
    },
    {
      "title": "dns-adguard — error rate (5m)",
      "expr": "rate(cave_home_dns_adguard_error_total[5m])"
    },
    {
      "title": "dns-adguard — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_dns_adguard_request_seconds_bucket[5m]))"
    },
    {
      "title": "dns-adguard — active entities / sessions",
      "expr": "cave_home_dns_adguard_active_total"
    },
    {
      "title": "dns-adguard — bytes in/out",
      "expr": "rate(cave_home_dns_adguard_bytes_in_total[1m]) + rate(cave_home_dns_adguard_bytes_out_total[1m])"
    },
    {
      "title": "dns-adguard — last-success age (s)",
      "expr": "time() - cave_home_dns_adguard_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Internet name lookups slowed down"
}
