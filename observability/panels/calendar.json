{
  "_comment": "cave-home-calendar Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Calendar feed (CalDAV).",
  "_planned_panels": [
    {
      "title": "calendar — event/tick rate",
      "expr": "rate(cave_home_calendar_tick_total[1m])"
    },
    {
      "title": "calendar — error rate (5m)",
      "expr": "rate(cave_home_calendar_error_total[5m])"
    },
    {
      "title": "calendar — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_calendar_request_seconds_bucket[5m]))"
    },
    {
      "title": "calendar — active entities / sessions",
      "expr": "cave_home_calendar_active_total"
    },
    {
      "title": "calendar — bytes in/out",
      "expr": "rate(cave_home_calendar_bytes_in_total[1m]) + rate(cave_home_calendar_bytes_out_total[1m])"
    },
    {
      "title": "calendar — last-success age (s)",
      "expr": "time() - cave_home_calendar_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Calendar feed stopped updating"
}
