{
  "_comment": "cave-home-solar-hoymiles Grafana panels — Phase 1 stub. Real dashboard JSON lands when the observability M3 crate ships and this integration exports the named metrics. Domain: Hoymiles microinverter cloud.",
  "_planned_panels": [
    {
      "title": "solar-hoymiles — event/tick rate",
      "expr": "rate(cave_home_solar_hoymiles_tick_total[1m])"
    },
    {
      "title": "solar-hoymiles — error rate (5m)",
      "expr": "rate(cave_home_solar_hoymiles_error_total[5m])"
    },
    {
      "title": "solar-hoymiles — request latency p50/p95/p99",
      "expr": "histogram_quantile(0.99, rate(cave_home_solar_hoymiles_request_seconds_bucket[5m]))"
    },
    {
      "title": "solar-hoymiles — active entities / sessions",
      "expr": "cave_home_solar_hoymiles_active_total"
    },
    {
      "title": "solar-hoymiles — bytes in/out",
      "expr": "rate(cave_home_solar_hoymiles_bytes_in_total[1m]) + rate(cave_home_solar_hoymiles_bytes_out_total[1m])"
    },
    {
      "title": "solar-hoymiles — last-success age (s)",
      "expr": "time() - cave_home_solar_hoymiles_last_success_timestamp_seconds"
    }
  ],
  "_charter_track": "observability",
  "_grandma_friendly": "Solar microinverters stopped reporting"
}
